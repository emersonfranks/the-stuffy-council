# Copy to `.env` for local dev. NEVER commit `.env`.

# ---- Server ----
# Bind address (0.0.0.0:8080 for containers, 127.0.0.1:8080 for local)
BIND_ADDR=127.0.0.1:8080

# Public origin used for absolute URLs, cookie scoping, and the GIS login_uri.
# For local dev use `http://localhost:8080` (NOT `127.0.0.1`) — Google Identity
# Services only allows plain HTTP on the literal `localhost` hostname.
# In production behind Azure ingress, set to the public HTTPS origin.
PUBLIC_ORIGIN=http://localhost:8080

# Set to `production` in Azure. Controls cookie Secure flag + logging.
APP_ENV=development

# ---- Storage ----
# SQLite file path. Use a persistent volume path in containers (e.g. /data/stuffy.sqlite).
DATABASE_URL=sqlite://stuffy-council.sqlite?mode=rwc

# ---- Google Sign-In (Identity Services) ----
# We use client-side Google Identity Services: Google's JS lib renders the
# sign-in button, handles the auth flow entirely on Google's side, and POSTs
# a signed ID token JWT to /auth/google/verify. Our server verifies the JWT
# with Google's public keys. There is NO client secret in this codebase.
#
# Create OAuth 2.0 credentials in Google Cloud Console
# (APIs & Services → Credentials → Create Credentials → OAuth client ID → Web application).
#   Authorized JavaScript origins:
#     Dev:  http://localhost:8080
#     Prod: https://<your-domain>
#   Authorized redirect URIs:
#     Dev:  http://localhost:8080/auth/google/verify
#     Prod: https://<your-domain>/auth/google/verify
# Paste the Client ID below. The Client Secret is not used and is never
# stored anywhere in this project.
GOOGLE_CLIENT_ID=

# Who's allowed to sign in is NOT here — it's in the committed
# `authorized-users.toml` at the repo root. Add or remove a user via PR.

# ---- LLM (Ollama) ----
# Ollama HTTP endpoint. Default is Ollama's local port.
OLLAMA_URL=http://127.0.0.1:11434
# Model tag pulled via `ollama pull <MODEL>`. Suggested defaults:
#   llama3.1:8b-instruct-q4_K_M   (balanced, ~5 GB)
#   mistral-nemo:12b-instruct     (better prose, ~7 GB)
#   qwen2.5:7b-instruct           (strong instruction following)
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
# Request timeout in seconds for a single generation call.
OLLAMA_TIMEOUT_SECS=120

# ---- Rate limiting ----
# Requests / second per client IP for the global limiter.
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=20
