# Copy to `.env` for local dev. NEVER commit `.env`.

# ---- Server ----
# Bind address (0.0.0.0:8080 for containers, 127.0.0.1:8080 for local)
BIND_ADDR=127.0.0.1:8080

# Public origin used for absolute URLs, cookie scoping, and CSRF.
# In production behind Azure ingress, set to the public HTTPS origin.
PUBLIC_ORIGIN=http://127.0.0.1:8080

# Set to `production` in Azure. Controls cookie Secure flag + logging.
APP_ENV=development

# ---- Sessions ----
# 64+ char random string. Generate: `openssl rand -hex 64`
SESSION_SECRET=change-me-64-hex-bytes-minimum-do-not-ship-this-value-in-any-real-deployment-anywhere

# ---- Storage ----
# SQLite file path. Use a persistent volume path in containers (e.g. /data/stuffy.sqlite).
DATABASE_URL=sqlite://stuffy-council.sqlite?mode=rwc

# ---- Google OAuth ----
# Create OAuth 2.0 credentials in Google Cloud Console (APIs & Services →
# Credentials → Create Credentials → OAuth client ID → Web application).
# Add authorized redirect URIs matching PUBLIC_ORIGIN:
#   Dev:  http://127.0.0.1:8080/auth/google/callback
#   Prod: https://<your-domain>/auth/google/callback
# Then paste the client id and secret here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. Defaults to `${PUBLIC_ORIGIN}/auth/google/callback`; set only
# if you need to override (e.g. proxying differs between origin and callback host).
# GOOGLE_REDIRECT_URL=http://127.0.0.1:8080/auth/google/callback

# ---- Access control ----
# Comma-separated Gmail addresses allowed to sign in. Anyone else gets a
# 403 after the Google round-trip, no matter how legitimate the Google
# session. Case-insensitive; whitespace trimmed. REQUIRED in production;
# an empty list in production is a boot error.
ALLOWED_EMAILS=franks.emerson@gmail.com

# ---- LLM (Ollama) ----
# Ollama HTTP endpoint. Default is Ollama's local port.
OLLAMA_URL=http://127.0.0.1:11434
# Model tag pulled via `ollama pull <MODEL>`. Suggested defaults:
#   llama3.1:8b-instruct-q4_K_M   (balanced, ~5 GB)
#   mistral-nemo:12b-instruct     (better prose, ~7 GB)
#   qwen2.5:7b-instruct           (strong instruction following)
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
# Request timeout in seconds for a single generation call.
OLLAMA_TIMEOUT_SECS=120

# ---- Rate limiting ----
# Requests / second per client IP for the global limiter.
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=20
